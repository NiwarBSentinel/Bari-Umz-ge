---
import { ShieldCheck, BadgeCheck, Clock, Sparkles } from "@lucide/astro";
---

<section id="garantien" class="relative py-16 md:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
      <div
        class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-widest uppercase text-accent-dark bg-accent-light/40 rounded-full"
      >
        Unsere Garantien
      </div>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-dark leading-tight mb-4"
      >
        Versprechen, die wir halten.
      </h2>
      <p class="text-base md:text-lg text-slate-600 leading-relaxed">
        Vier Garantien, damit Sie ohne Sorgen umziehen.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      <div
        class="group relative bg-white rounded-2xl p-6 md:p-7 border border-slate-200 shadow-sm hover:shadow-lg hover:border-accent/40 transition-all duration-300"
      >
        <div
          class="w-12 h-12 mb-4 rounded-xl bg-accent-light/40 flex items-center justify-center group-hover:bg-accent group-hover:scale-110 transition-all"
        >
          <BadgeCheck
            size={24}
            strokeWidth={2}
            class="text-accent-dark group-hover:text-white transition-colors"
          />
        </div>
        <h3 class="text-lg font-bold text-primary-dark mb-2">
          Festpreis nach Besichtigung
        </h3>
        <p class="text-sm text-slate-600 leading-relaxed">
          Nach einer kostenlosen Besichtigung garantieren wir Ihnen einen
          verbindlichen Festpreis — ohne versteckte Aufschläge.
        </p>
      </div>

      <div
        class="group relative bg-white rounded-2xl p-6 md:p-7 border border-slate-200 shadow-sm hover:shadow-lg hover:border-accent/40 transition-all duration-300"
      >
        <div
          class="w-12 h-12 mb-4 rounded-xl bg-accent-light/40 flex items-center justify-center group-hover:bg-accent group-hover:scale-110 transition-all"
        >
          <Clock
            size={24}
            strokeWidth={2}
            class="text-accent-dark group-hover:text-white transition-colors"
          />
        </div>
        <h3 class="text-lg font-bold text-primary-dark mb-2">
          Pünktlichkeits-Garantie
        </h3>
        <p class="text-sm text-slate-600 leading-relaxed">
          Verspätung von über 60 Min? Wir reduzieren den Preis um 10%.
          Pünktlichkeit ist Pflicht.
        </p>
      </div>

      <div
        class="group relative bg-white rounded-2xl p-6 md:p-7 border border-slate-200 shadow-sm hover:shadow-lg hover:border-accent/40 transition-all duration-300"
      >
        <div
          class="w-12 h-12 mb-4 rounded-xl bg-accent-light/40 flex items-center justify-center group-hover:bg-accent group-hover:scale-110 transition-all"
        >
          <ShieldCheck
            size={24}
            strokeWidth={2}
            class="text-accent-dark group-hover:text-white transition-colors"
          />
        </div>
        <h3 class="text-lg font-bold text-primary-dark mb-2">
          CHF 5 Mio. Versichert
        </h3>
        <p class="text-sm text-slate-600 leading-relaxed">
          Unsere Haftpflichtversicherung deckt jeden Umzug bis CHF 5 Mio. ab.
          Ihre Möbel sind sicher.
        </p>
      </div>

      <div
        class="group relative bg-white rounded-2xl p-6 md:p-7 border border-slate-200 shadow-sm hover:shadow-lg hover:border-accent/40 transition-all duration-300"
      >
        <div
          class="absolute top-3 right-3 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white bg-accent rounded-full"
        >
          Reinigung
        </div>
        <div
          class="w-12 h-12 mb-4 rounded-xl bg-accent-light/40 flex items-center justify-center group-hover:bg-accent group-hover:scale-110 transition-all"
        >
          <Sparkles
            size={24}
            strokeWidth={2}
            class="text-accent-dark group-hover:text-white transition-colors"
          />
        </div>
        <h3 class="text-lg font-bold text-primary-dark mb-2">
          Abnahme-Garantie
        </h3>
        <p class="text-sm text-slate-600 leading-relaxed">
          Wohnungsabnahme nicht bestanden? Wir reinigen kostenlos nach. So lange
          bis es passt.
        </p>
      </div>
    </div>
  </div>
</section>
