---
import { Check, X, ArrowRight } from "@lucide/astro";

// TODO NIWAR: Diese Vergleichswerte vor Live-Gang final prüfen.
//   Nur Behauptungen drinlassen, die Bari faktisch erfüllt
//   (Wettbewerbs-/UWG-Risiko bei "irreführender vergleichender Werbung").
//   Insbesondere prüfen:
//     - "Vollkasko-Versicherung inklusive" — passt das zur "CHF 5 Mio.
//       Haftpflicht"-Aussage in <Guarantees>? Konsistent halten.
//     - "Festangestellte Umzugshelfer" — Personalstruktur faktisch?
//     - "Nur +20% Wochenend-Zuschlag" — exakter Tarif aktuell?
//     - "Schriftlich garantiert" (Tiefpreisgarantie) — gibt es das Dokument?

interface ComparisonRow {
  criterion: string;
  others: string;
  bari: string;
  highlight?: boolean;
}

const comparisonRows: ComparisonRow[] = [
  {
    criterion: "Offerte erhalten",
    others: "24–72 Stunden Wartezeit",
    bari: "Sofort in unter 2 Minuten",
    highlight: true,
  },
  {
    criterion: "Preisberechnung",
    others: "Intransparent, oft erst nach Besichtigung",
    bari: "Transparente Aufschlüsselung – Sie sehen jeden Posten",
  },
  {
    criterion: "Tiefpreisgarantie",
    others: "Selten oder nur auf Anfrage",
    bari: "Schriftlich garantiert",
  },
  {
    criterion: "Festpreis-Sicherheit",
    others: "Häufig versteckte Zusatzkosten",
    bari: "Verbindlicher Festpreis nach Besichtigung",
  },
  {
    criterion: "Eigenes Personal",
    others: "Oft Subunternehmer ohne Schulung",
    bari: "Festangestellte, geschulte Umzugshelfer",
  },
  {
    criterion: "Versicherung",
    others: "Basis-Haftpflicht (oft <CHF 5'000)",
    bari: "Vollkasko-Versicherung inklusive",
  },
  {
    criterion: "Erreichbarkeit",
    others: "Bürozeiten Mo–Fr",
    bari: "WhatsApp-Direktkontakt 7 Tage",
  },
  {
    criterion: "Zusatzleistungen",
    others: "Aufpreis für jede Kleinigkeit",
    bari: "Kartons, Ab-/Aufbau, Reinigung – alles aus einer Hand",
  },
  {
    criterion: "Wochenend-Umzug",
    others: "+30–50% Zuschlag",
    bari: "Nur +20% Zuschlag",
  },
  {
    criterion: "Erfahrung in der Schweiz",
    others: "Variabel",
    bari: "Lokale Expertise, kennt jede Schweizer Region",
  },
];
---

<section
  id="vergleich"
  class="relative py-16 md:py-24 bg-white"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
      <div
        class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-widest uppercase text-accent-dark bg-accent-light/40 rounded-full"
      >
        Der Bari-Unterschied
      </div>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-dark leading-tight mb-4"
      >
        Warum Bari Umzüge — und nicht irgendein Anbieter
      </h2>
      <p class="text-base md:text-lg text-slate-600 leading-relaxed">
        Wir haben Schweizer Umzüge neu gedacht. Hier sehen Sie, was uns von
        anderen Umzugsfirmen unterscheidet.
      </p>
    </div>

    <!-- Desktop table -->
    <div class="hidden md:block max-w-5xl mx-auto">
      <div class="relative pt-6">
        <!-- Highlight overlay behind Bari column -->
        <div
          aria-hidden="true"
          class="absolute top-6 bottom-0 right-0 w-[35%] bg-accent-light/40 border-2 border-accent/40 rounded-2xl shadow-xl shadow-accent/10 pointer-events-none"
        >
        </div>

        <!-- "Empfohlen" badge -->
        <div
          aria-hidden="true"
          class="absolute top-0 right-0 w-[35%] flex justify-center pointer-events-none z-10"
        >
          <span
            class="inline-flex items-center bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full shadow-md"
          >
            Empfohlen
          </span>
        </div>

        <table class="relative w-full border-collapse table-fixed">
          <caption class="sr-only">
            Vergleich: Bari Umzüge gegenüber typischen Schweizer Umzugsanbietern
          </caption>
          <colgroup>
            <col style="width: 30%" />
            <col style="width: 35%" />
            <col style="width: 35%" />
          </colgroup>
          <thead>
            <tr>
              <th
                scope="col"
                class="text-left text-xs font-bold text-slate-500 uppercase tracking-wide pt-6 pb-4 px-5"
              >
                Kriterium
              </th>
              <th
                scope="col"
                class="text-left text-xs font-bold text-slate-500 uppercase tracking-wide pt-6 pb-4 px-5"
              >
                Andere Anbieter
              </th>
              <th
                scope="col"
                class="text-left text-xs font-bold text-accent-dark uppercase tracking-wide pt-6 pb-4 px-5"
              >
                Bari Umzüge
              </th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, idx) => (
              <tr class={idx > 0 ? "border-t border-slate-200/70" : ""}>
                <th
                  scope="row"
                  class={`py-5 px-5 text-left font-bold text-primary-dark align-top ${row.highlight ? "text-base md:text-lg" : "text-sm md:text-base"}`}
                >
                  {row.criterion}
                </th>
                <td
                  class={`py-5 px-5 align-top text-slate-600 ${row.highlight ? "text-base" : "text-sm md:text-base"}`}
                >
                  <span class="flex items-start gap-2">
                    <X
                      size={18}
                      strokeWidth={2.5}
                      class="text-slate-400 flex-shrink-0 mt-0.5"
                      aria-label="nicht enthalten"
                    />
                    <span>{row.others}</span>
                  </span>
                </td>
                <td
                  class={`py-5 px-5 align-top text-slate-800 font-medium ${row.highlight ? "text-base md:text-lg" : "text-sm md:text-base"}`}
                >
                  <span class="flex items-start gap-2">
                    <Check
                      size={18}
                      strokeWidth={2.5}
                      class="text-accent-dark flex-shrink-0 mt-0.5"
                      aria-label="enthalten"
                    />
                    <span>{row.bari}</span>
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden space-y-4 max-w-md mx-auto">
      {comparisonRows.map((row) => (
        <article
          class={`rounded-2xl border bg-white shadow-sm p-5 space-y-3 ${row.highlight ? "border-accent/50 shadow-accent/10" : "border-slate-200"}`}
        >
          <p class="text-xs font-bold uppercase tracking-wide text-slate-500">
            {row.criterion}
          </p>
          <dl class="space-y-2">
            <div class="flex items-start gap-2">
              <X
                size={18}
                strokeWidth={2.5}
                class="text-slate-400 flex-shrink-0 mt-0.5"
                aria-label="nicht enthalten"
              />
              <div class="flex-1 min-w-0">
                <dt class="text-[11px] font-semibold uppercase tracking-wide text-slate-400">
                  Andere Anbieter
                </dt>
                <dd class="text-sm text-slate-600">{row.others}</dd>
              </div>
            </div>
            <div
              class="flex items-start gap-2 bg-accent-light/40 border-l-4 border-accent rounded-r-lg p-3 -ml-1"
            >
              <Check
                size={18}
                strokeWidth={2.5}
                class="text-accent-dark flex-shrink-0 mt-0.5"
                aria-label="enthalten"
              />
              <div class="flex-1 min-w-0">
                <dt class="text-[11px] font-semibold uppercase tracking-wide text-accent-dark">
                  Bari Umzüge
                </dt>
                <dd class="text-sm text-slate-800 font-medium">{row.bari}</dd>
              </div>
            </div>
          </dl>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 md:mt-16 text-center max-w-2xl mx-auto">
      <p class="text-lg md:text-xl font-bold text-primary-dark mb-5">
        Überzeugt? Holen Sie Ihre Sofort-Offerte in 2 Minuten.
      </p>
      <a
        href="/offerte"
        class="inline-flex items-center gap-2 bg-primary hover:bg-primary-light text-white font-bold text-base px-7 py-4 rounded-2xl shadow-lg shadow-primary/30 transition-all hover:shadow-xl hover:shadow-primary/40 hover:scale-[1.02]"
      >
        Jetzt kostenlose Offerte berechnen
        <ArrowRight size={20} strokeWidth={2.5} />
      </a>
    </div>
  </div>
</section>
