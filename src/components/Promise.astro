---
import { PackageCheck, Clock, Users, Receipt } from "@lucide/astro";

const values = [
  {
    Icon: PackageCheck,
    title: "Sorgfalt",
    text: "Möbel werden sorgfältig verpackt, sicher fixiert und versichert transportiert. Bis zu CHF 2 Mio. Haftpflicht.",
    iconClass: "",
  },
  {
    Icon: Clock,
    title: "Pünktlich",
    text: "Zugesagte Termine werden eingehalten. Wir arbeiten effizient — damit Sie schnell ankommen.",
    iconClass: "",
  },
  {
    Icon: Users,
    title: "Erfahren",
    text: "Festes Team mit jahrelanger Erfahrung. Keine Tagelöhner, keine Überraschungen.",
    iconClass: "",
  },
  {
    Icon: Receipt,
    title: "Fair",
    text: "Transparente Pauschalpreise nach Volumen. Keine versteckten Kosten, keine Tricks.",
    iconClass: "",
  },
];
---

<section id="versprechen" class="bg-dark py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal-up max-w-3xl">
      <p class="text-accent uppercase tracking-[0.25em] text-xs sm:text-sm font-semibold mb-4">
        Unser Versprechen
      </p>
      <h2 class="text-white font-extrabold tracking-tight text-4xl sm:text-5xl leading-[1.1]">
        Ihre Sachen in besten Händen.
      </h2>
      <p class="mt-4 text-lg text-white/60">
        Vier Werte, die jeden Umzug mit uns ausmachen.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        values.map(({ Icon, title, text, iconClass }, idx) => (
          <div
            class="promise-card group reveal-scale border border-white/10 rounded-2xl p-7"
            style={`--reveal-delay: ${idx * 80}ms`}
          >
            <div class="mb-5">
              <Icon
                size={32}
                strokeWidth={1.75}
                class={`promise-icon text-white group-hover:text-accent ${iconClass}`}
              />
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{title}</h3>
            <p class="text-sm text-white/70 leading-relaxed">{text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
