---
import { Heart } from "@lucide/astro";

const cols = [
  {
    title: "Services",
    items: [
      { href: "/#services", label: "Privat-Umzug" },
      { href: "/#services", label: "Firmen-Umzug" },
      { href: "/#services", label: "Lager & Reinigung" },
    ],
  },
  {
    title: "Unternehmen",
    items: [
      { href: "/#versprechen", label: "Über uns" },
      { href: "/#garantien", label: "Garantien" },
      { href: "/#referenzen", label: "Referenzen" },
      { href: "/#kontakt", label: "Kontakt" },
    ],
  },
  {
    title: "Rechtliches",
    items: [
      { href: "/impressum", label: "Impressum" },
      { href: "/datenschutz", label: "Datenschutz" },
      { href: "/agb", label: "AGB" },
    ],
  },
];
---

<footer class="bg-dark text-white/70">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a
          href="/"
          class="flex items-center gap-2 group"
          aria-label="Bari Umzüge - Startseite"
        >
          <span class="text-2xl font-extrabold tracking-tight leading-none">
            <span class="text-white">Bari</span><span
              class="text-accent ml-1.5">Umzüge</span>
          </span>
        </a>
        <p class="mt-4 text-sm leading-relaxed">
          Ihr Umzugsservice in der ganzen Deutschschweiz.
        </p>
      </div>
      {
        cols.map((col) => (
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-widest mb-5">
              {col.title}
            </h3>
            <ul class="space-y-3 text-sm">
              {col.items.map((item) => (
                <li>
                  <a href={item.href} class="hover:text-accent transition">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div
      class="mt-14 pt-8 border-t border-white/10 text-xs text-white/50 text-center flex items-center justify-center flex-wrap gap-1"
    >
      <span>© 2026 Bari Umzüge GmbH · Mitglied SMV · Made with</span>
      <Heart size={14} fill="currentColor" class="inline text-accent" />
      <span>in der Schweiz</span>
    </div>

    <div class="footer-credit">
      <a
        href="https://www.smartbranding.ch/"
        target="_blank"
        rel="noopener noreferrer"
        class="sb-credit"
        aria-label="Webdesign by Smart Branding"
      >
        <span class="sb-credit__text">Made with</span>
        <span class="sb-credit__heart" aria-hidden="true">❤️</span>
        <span class="sb-credit__text sb-credit__by">by</span>
        <img
          src="/images/smartbranding-logo.svg"
          alt="Smart Branding"
          class="sb-credit__logo"
          width="331"
          height="82"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-credit {
    text-align: center;
    margin-top: 0.875rem;
    padding: 0 1rem;
  }

  .sb-credit {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .sb-credit:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .sb-credit__by {
    margin-left: 0.1rem;
  }

  .sb-credit__heart {
    font-size: 0.875rem;
    line-height: 1;
  }

  .sb-credit__logo {
    height: 18px;
    width: auto;
    margin-left: 0.15rem;
    vertical-align: middle;
    /* Logo ist schwarz; auf dem dunklen Footer ohne Filter unsichtbar. */
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: opacity 200ms ease;
  }
  .sb-credit:hover .sb-credit__logo {
    opacity: 1;
  }
</style>
