---
import { Star, Quote } from "@lucide/astro";

const testimonials = [
  {
    name: "Sandra K.",
    location: "Zürich",
    date: "März 2026",
    rating: 5,
    initial: "S",
    quote:
      "Top Service vom ersten Anruf bis zum letzten Karton. Pünktlich, freundlich und keine versteckten Kosten. Genau so wünscht man sich einen Umzug.",
    move: "3-Zimmer · Zürich → Winterthur",
  },
  {
    name: "Marco B.",
    location: "Winterthur",
    date: "Februar 2026",
    rating: 5,
    initial: "M",
    quote:
      "Wir hatten ein Klavier und Sorgen. Das Team von Bari hat es professionell verpackt und ohne einen Kratzer in den 3. Stock geliefert. Empfehlung!",
    move: "Klaviertransport · Hausumzug",
  },
  {
    name: "Familie Müller",
    location: "Wallisellen",
    date: "Januar 2026",
    rating: 5,
    initial: "F",
    quote:
      "Mit drei Kindern war der Umzug eine logistische Herausforderung. Bari hat alles übernommen, sogar die Endreinigung. Stresslos und pünktlich.",
    move: "5-Zimmer Familienumzug",
  },
  {
    name: "Lisa H.",
    location: "Uster",
    date: "Dezember 2025",
    rating: 5,
    initial: "L",
    quote:
      "Spontaner Umzug innert 2 Wochen — Bari hat es trotzdem möglich gemacht. Faires Pauschalangebot und das Team war super effizient. Vielen Dank!",
    move: "2-Zimmer · Eilt-Umzug",
  },
];
---

<section id="referenzen" class="relative py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-12 md:mb-16">
      <div
        class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-widest uppercase text-accent-dark bg-accent-light/40 rounded-full"
      >
        Kundenstimmen
      </div>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-dark leading-tight mb-4"
      >
        487 Bewertungen.<br />
        <span class="text-accent">Ø 4.9 von 5 Sternen.</span>
      </h2>
      <p class="text-base md:text-lg text-slate-600 leading-relaxed">
        Echte Stimmen von echten Kunden aus der ganzen Deutschschweiz.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {
        testimonials.map((t) => (
          <div class="relative bg-slate-50 rounded-2xl p-6 md:p-7 border border-slate-200 hover:shadow-lg hover:border-accent/30 transition-all duration-300 flex flex-col">
            <Quote
              size={32}
              strokeWidth={2}
              class="absolute top-5 right-5 text-accent/15"
            />

            <div class="flex gap-0.5 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <Star
                  size={16}
                  strokeWidth={2}
                  fill="currentColor"
                  class="text-accent"
                />
              ))}
            </div>

            <p class="text-sm text-slate-700 leading-relaxed mb-5 flex-1">
              «{t.quote}»
            </p>

            <div class="flex items-center gap-3 pt-4 border-t border-slate-200">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                {t.initial}
              </div>
              <div class="min-w-0">
                <div class="text-sm font-semibold text-primary-dark truncate">
                  {t.name}
                </div>
                <div class="text-xs text-slate-500 truncate">
                  {t.location} · {t.date}
                </div>
              </div>
            </div>

            <div class="mt-3 inline-block self-start px-2.5 py-1 text-[11px] font-medium text-accent-dark bg-accent-light/40 rounded-full">
              {t.move}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-12 md:mt-16 pt-10 border-t border-slate-200 text-center">
      <p
        class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-4"
      >
        Bewertet auf
      </p>
      <div
        class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-semibold text-slate-400"
      >
        <span>Google · 4.9 ★</span>
        <span class="text-slate-300">·</span>
        <span>Trustpilot · 4.8 ★</span>
        <span class="text-slate-300">·</span>
        <span>Local.ch · 5.0 ★</span>
      </div>
    </div>
  </div>
</section>
