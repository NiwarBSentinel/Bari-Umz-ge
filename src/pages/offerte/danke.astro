---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Check, Phone, ArrowLeft, MessageCircle } from "@lucide/astro";

const title = "Anfrage erhalten · Bari Umzüge";
const description = "Vielen Dank für Ihre Offerten-Anfrage.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/offerte/danke"
  solidHeader={true}
  robots="noindex, nofollow"
  bodyClass="bg-slate-50 text-dark antialiased"
>
  <div class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div
        class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 mb-6"
      >
        <Check size={40} strokeWidth={3} class="text-emerald-600" />
      </div>

      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4 leading-tight"
      >
        Anfrage erfolgreich gesendet!
      </h1>

      <p class="text-lg text-slate-600 mb-8 leading-relaxed">
        Vielen Dank für Ihr Vertrauen. Wir prüfen Ihre Angaben und melden uns
        <strong class="text-slate-900">innerhalb von 24h werktags</strong> bei Ihnen
        mit einer detaillierten Offerte.
      </p>

      <div
        class="bg-white rounded-3xl border border-slate-200/70 shadow-lg shadow-slate-200/40 p-6 md:p-8 mb-8 text-left"
      >
        <h2 class="text-base font-bold text-slate-900 mb-4">Was passiert jetzt?</h2>
        <ol class="space-y-3 text-sm text-slate-700">
          <li class="flex items-start gap-3">
            <span
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-light/40 text-accent-dark font-bold text-xs flex items-center justify-center"
              >1</span
            >
            <span>Wir prüfen Ihre Angaben und kalkulieren die Offerte.</span>
          </li>
          <li class="flex items-start gap-3">
            <span
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-light/40 text-accent-dark font-bold text-xs flex items-center justify-center"
              >2</span
            >
            <span>Sie erhalten innerhalb von 24h werktags eine schriftliche Offerte per E-Mail.</span>
          </li>
          <li class="flex items-start gap-3">
            <span
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-light/40 text-accent-dark font-bold text-xs flex items-center justify-center"
              >3</span
            >
            <span>Bei Fragen rufen wir Sie an oder Sie erreichen uns jederzeit unter
              <a
                href="tel:+41445551234"
                class="text-primary font-semibold hover:underline"
                >044 555 12 34</a
              >.</span>
          </li>
        </ol>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold px-7 py-4 rounded-2xl shadow-lg shadow-primary/30 transition-all hover:shadow-xl hover:shadow-primary/40 hover:scale-[1.02]"
        >
          <ArrowLeft size={20} strokeWidth={2.5} />
          Zurück zur Startseite
        </a>
        <a
          href="tel:+41445551234"
          class="inline-flex items-center justify-center gap-2 bg-accent text-primary font-bold px-7 py-4 rounded-2xl shadow-md transition-all hover:scale-[1.02]"
        >
          <Phone size={20} strokeWidth={2.5} />
          044 555 12 34
        </a>
      </div>

      <p class="text-sm text-slate-500 mt-8 inline-flex items-center gap-2">
        <MessageCircle size={14} strokeWidth={2} />
        <span
          >Schneller? Schreiben Sie uns auf
          <a
            href="https://wa.me/41445551234"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary font-semibold hover:underline">WhatsApp</a
          >.</span
        >
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    const STORAGE_PREFIX = "bari_offerte_v1_";
    try {
      sessionStorage.removeItem(STORAGE_PREFIX + "data");
      sessionStorage.removeItem(STORAGE_PREFIX + "step");
      sessionStorage.removeItem(STORAGE_PREFIX + "submitted");
    } catch (e) {
      /* ignore */
    }
  })();
</script>
