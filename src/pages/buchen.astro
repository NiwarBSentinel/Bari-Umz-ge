---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  ArrowLeft,
  ArrowRight,
  Check,
  MapPin,
  Calendar,
  Truck,
  Info,
} from "@lucide/astro";

const title = "Offerte anfragen · Bari Umzüge";
const description = "Schritt 2 von 2: Offerte prüfen und absenden.";
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={title}
  ogDescription={description}
  canonicalPath="/buchen"
  solidHeader={true}
  robots="noindex, nofollow"
  bodyClass="bg-slate-50 text-dark antialiased"
>
  <div class="pt-32 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-slate-600 hover:text-primary mb-6 text-sm font-medium transition-colors"
      >
        <ArrowLeft size={16} strokeWidth={2} />
        Zurück zur Startseite
      </a>

      <!-- Step Indicator -->
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center text-white shadow-md"
          >
            <Check size={16} strokeWidth={3} />
          </div>
          <span class="text-sm font-semibold text-slate-700 hidden sm:inline"
            >Adressen</span
          >
        </div>
        <div class="flex-1 h-0.5 bg-emerald-500 max-w-[60px]"></div>
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold shadow-md"
          >
            2
          </div>
          <span class="text-sm font-semibold text-primary hidden sm:inline"
            >Bestätigung</span
          >
        </div>
        <div class="flex-1 h-0.5 bg-slate-200 max-w-[60px]"></div>
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 rounded-full border-2 border-slate-300 text-slate-400 flex items-center justify-center font-bold"
          >
            3
          </div>
          <span class="text-sm font-medium text-slate-400 hidden sm:inline"
            >Team</span
          >
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-2">
        Offerte anfragen
      </h1>
      <p class="text-slate-600 mb-8">
        Schritt 2 von 2 · Prüfen Sie Ihre Anfrage und senden Sie ab.
      </p>

      <!-- Adressen-Card -->
      <div
        class="bg-white rounded-3xl border border-slate-200/70 shadow-lg shadow-slate-200/40 overflow-hidden mb-6"
      >
        <div class="px-6 md:px-8 py-5 border-b border-slate-100">
          <h2 class="text-lg font-bold text-slate-900">Ihre Anfrage</h2>
        </div>
        <div class="p-6 md:p-8">
          <div class="flex items-start gap-4 py-4 border-b border-slate-100">
            <div
              class="w-11 h-11 rounded-lg bg-accent-light/30 flex items-center justify-center flex-shrink-0"
            >
              <MapPin size={20} strokeWidth={2} class="text-accent-dark" />
            </div>
            <div class="flex-1 min-w-0">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Auszug
              </p>
              <p
                id="summary-from"
                class="text-base font-medium text-slate-900 break-words"
              >
                —
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4 py-4 border-b border-slate-100">
            <div
              class="w-11 h-11 rounded-lg bg-accent-light/30 flex items-center justify-center flex-shrink-0"
            >
              <MapPin size={20} strokeWidth={2} class="text-accent-dark" />
            </div>
            <div class="flex-1 min-w-0">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Einzug
              </p>
              <p
                id="summary-to"
                class="text-base font-medium text-slate-900 break-words"
              >
                —
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4 py-4">
            <div
              class="w-11 h-11 rounded-lg bg-accent-light/30 flex items-center justify-center flex-shrink-0"
            >
              <Calendar size={20} strokeWidth={2} class="text-accent-dark" />
            </div>
            <div class="flex-1">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Wunschdatum
              </p>
              <p id="summary-when" class="text-base font-medium text-slate-900">
                —
              </p>
            </div>
          </div>

          <a
            href="/"
            class="text-sm text-primary hover:underline mt-4 inline-block"
          >
            ← Anfrage ändern
          </a>
        </div>
      </div>

      <!-- Umfang-Card -->
      <div
        class="bg-white rounded-3xl border border-slate-200/70 shadow-lg shadow-slate-200/40 overflow-hidden mb-6"
      >
        <div class="px-6 md:px-8 py-5 border-b border-slate-100">
          <h2 class="text-lg font-bold text-slate-900">Umfang Ihres Umzugs</h2>
        </div>
        <div class="p-6 md:p-8 space-y-5">
          <label class="block">
            <span class="text-sm font-semibold text-slate-700 mb-2 block"
              >Wohnungsgrösse</span
            >
            <select
              id="apartment-size"
              class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent-light/30 outline-none font-medium text-slate-900 bg-white transition"
            >
              <option value="600">1-Zimmer · max 15 m³</option>
              <option value="950" selected>2-Zimmer · max 30 m³</option>
              <option value="1400">3-Zimmer · max 45 m³</option>
              <option value="1900">4-Zimmer · max 60 m³</option>
              <option value="2500">5+ Zimmer · max 80 m³</option>
            </select>
          </label>

          <label class="block">
            <span class="text-sm font-semibold text-slate-700 mb-2 block">
              Stockwerke ohne Lift
              <span class="text-xs text-slate-500 font-normal"
                >(Auszug + Einzug zusammen)</span
              >
            </span>
            <input
              id="stockwerke-no-lift"
              type="number"
              min="0"
              max="20"
              value="0"
              class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent-light/30 outline-none font-medium text-slate-900 transition"
            />
          </label>
        </div>
      </div>

      <!-- Endreinigung Add-On -->
      <div class="bg-white rounded-3xl border border-slate-200/70 shadow-lg shadow-slate-200/40 p-6 md:p-8 mb-6">
        <div class="flex items-start gap-4 mb-5">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <h2 class="text-lg font-bold text-slate-900">Endreinigung dazubuchen?</h2>
              <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-accent-dark bg-accent-light/40 rounded-full">
                Optional
              </span>
            </div>
            <p class="text-sm text-slate-600">
              Wir übernehmen die Endreinigung — mit optionaler Abnahmegarantie.
            </p>
          </div>

          <label class="relative inline-flex items-center cursor-pointer flex-shrink-0 mt-1">
            <input type="checkbox" id="cleaning-toggle" class="sr-only peer" />
            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent-light rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent">
            </div>
          </label>
        </div>

        <div id="cleaning-options" class="hidden">
          <div class="border-t border-slate-200 pt-5 space-y-4">
            <div class="flex items-start justify-between gap-3 p-4 rounded-xl bg-slate-50">
              <div>
                <div class="text-sm font-semibold text-slate-900 mb-0.5">
                  Endreinigung · <span id="cleaning-size-label">2-Zimmer</span>
                </div>
                <div class="text-xs text-slate-600">
                  Komplette Endreinigung inkl. Küche, Bad, Boden
                </div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-base font-bold text-primary-dark">
                  CHF <span id="cleaning-base-price">500</span>
                </div>
                <div class="text-[11px] text-slate-500">Pauschal</div>
              </div>
            </div>

            <label class="flex items-start gap-3 p-4 rounded-xl border-2 border-slate-200 hover:border-accent/40 cursor-pointer transition-all">
              <input type="checkbox" id="guarantee-toggle"
                class="mt-1 w-5 h-5 rounded text-accent focus:ring-accent" />
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-3 mb-1 flex-wrap">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-slate-900">Abnahmegarantie</span>
                    <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white bg-accent rounded-full">Empfohlen</span>
                  </div>
                  <div class="text-sm font-bold text-primary-dark">
                    + CHF <span id="guarantee-price">200</span>
                  </div>
                </div>
                <div class="text-xs text-slate-600 leading-relaxed">
                  Verwaltung lehnt die Reinigung ab? Wir reinigen kostenlos nach —
                  so oft wie nötig, bis die Wohnung abgenommen ist.
                </div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- Offerte-Card -->
      <div
        class="bg-white rounded-3xl border border-slate-200/70 shadow-lg shadow-slate-200/40 overflow-hidden mb-6"
      >
        <div class="px-6 md:px-8 py-5 border-b border-slate-100">
          <h2 class="text-lg font-bold text-slate-900">Ihre Offerte</h2>
        </div>
        <div class="p-6 md:p-8">
          <div
            id="offer-card"
            class="border border-primary/30 bg-gradient-to-br from-primary/5 to-white rounded-2xl p-5 flex items-center gap-5 shadow-md shadow-primary/10 transition-all duration-300 hover:shadow-lg hover:shadow-primary/20"
          >
            <div
              class="w-14 h-14 rounded-xl bg-primary flex items-center justify-center flex-shrink-0 shadow-md shadow-primary/30"
            >
              <Truck size={28} strokeWidth={2} class="text-white" />
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="text-base font-bold text-slate-900">Komplett-Service</h3>
              <p id="travel-time" class="text-sm text-slate-500 mt-0.5">
                Wird berechnet…
              </p>
            </div>

            <div class="text-right">
              <p
                id="price-display"
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-none"
              >
                <span
                  class="inline-block bg-slate-200 rounded-md animate-pulse w-24 h-8 md:h-9"
                ></span>
              </p>
              <p id="distance-display" class="text-xs text-slate-500 mt-1"></p>
            </div>
          </div>

          <div id="price-breakdown" class="hidden mt-4 pt-4 border-t border-slate-200 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-slate-600">Umzug</span>
              <span class="font-semibold text-slate-900">CHF <span id="bd-move">0</span></span>
            </div>
            <div class="flex justify-between" id="bd-cleaning-row">
              <span class="text-slate-600">Endreinigung</span>
              <span class="font-semibold text-slate-900">CHF <span id="bd-cleaning">0</span></span>
            </div>
            <div class="flex justify-between hidden" id="bd-guarantee-row">
              <span class="text-slate-600">Abnahmegarantie</span>
              <span class="font-semibold text-slate-900">CHF <span id="bd-guarantee">0</span></span>
            </div>
          </div>

          <p
            id="price-disclaimer"
            class="text-xs text-slate-500 mt-5 leading-relaxed inline-flex items-start gap-1.5"
          >
            <Info
              size={14}
              strokeWidth={2}
              class="flex-shrink-0 mt-0.5 text-slate-400"
            />
            <span
              >Pauschalpreis basierend auf gewählter Wohnungsgrösse, Stockwerken
              ohne Lift und Distanz. Endpreis kann nach Besichtigung leicht
              abweichen.</span
            >
          </p>
        </div>
      </div>

      <!-- Sticky Footer -->
      <div
        class="bg-white rounded-3xl border border-slate-200/70 shadow-2xl shadow-slate-900/10 p-6 flex items-center justify-between gap-4 sticky bottom-4 lg:static z-20"
      >
        <div>
          <p
            class="text-xs text-slate-500 font-semibold uppercase tracking-wide"
          >
            Richtpreis
          </p>
          <p
            id="total-price"
            class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-none mt-1"
          >
            <span
              class="inline-block bg-slate-200 rounded-md animate-pulse w-32 h-8 md:h-10"
            ></span>
          </p>
        </div>

        <button
          id="confirm-btn"
          type="button"
          class="bg-primary hover:bg-primary-light text-white font-bold px-7 py-4 rounded-2xl flex items-center gap-2 shadow-lg shadow-primary/30 transition-all hover:shadow-xl hover:shadow-primary/40 hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          disabled
        >
          <span class="hidden sm:inline">Per WhatsApp bestätigen</span>
          <span class="sm:hidden">Bestätigen</span>
          <ArrowRight size={20} strokeWidth={2.5} />
        </button>
      </div>

      <div class="text-center mt-8">
        <p class="text-sm text-slate-600">
          Lieber direkt anrufen?
          <a
            href="tel:+41000000000"
            class="text-primary font-semibold hover:underline ml-1"
          >
            +41 00 000 00 00
          </a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const from = (params.get("from") || "").trim();
    const to = (params.get("to") || "").trim();
    const whenRaw = (params.get("when") || "").trim();
    let when = whenRaw;
    if (whenRaw && /^\d{4}-\d{2}-\d{2}$/.test(whenRaw)) {
      try {
        when = new Date(whenRaw).toLocaleDateString("de-CH", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        });
      } catch (e) {
        when = whenRaw;
      }
    }
    const fromLat = params.get("fromLat");
    const fromLon = params.get("fromLon");
    const toLat = params.get("toLat");
    const toLon = params.get("toLon");

    if (!from || !to) {
      window.location.href = "/";
      return;
    }

    const summaryFrom = document.getElementById("summary-from");
    const summaryTo = document.getElementById("summary-to");
    const summaryWhen = document.getElementById("summary-when");
    const priceDisplay = document.getElementById("price-display");
    const totalPrice = document.getElementById("total-price");
    const distanceDisplay = document.getElementById("distance-display");
    const travelTime = document.getElementById("travel-time");
    const disclaimer = document.getElementById("price-disclaimer");
    const confirmBtn = document.getElementById("confirm-btn");
    const sizeSelect = document.getElementById("apartment-size");
    const stockwerkInput = document.getElementById("stockwerke-no-lift");
    const cleaningToggle = document.getElementById("cleaning-toggle");
    const cleaningOptions = document.getElementById("cleaning-options");
    const guaranteeToggle = document.getElementById("guarantee-toggle");
    const cleaningSizeLabel = document.getElementById("cleaning-size-label");
    const cleaningBasePriceEl = document.getElementById("cleaning-base-price");
    const guaranteePriceEl = document.getElementById("guarantee-price");
    const breakdownEl = document.getElementById("price-breakdown");
    const bdMove = document.getElementById("bd-move");
    const bdCleaning = document.getElementById("bd-cleaning");
    const bdGuarantee = document.getElementById("bd-guarantee");
    const bdCleaningRow = document.getElementById("bd-cleaning-row");
    const bdGuaranteeRow = document.getElementById("bd-guarantee-row");

    if (summaryFrom) summaryFrom.textContent = from;
    if (summaryTo) summaryTo.textContent = to;
    if (summaryWhen) summaryWhen.textContent = when || "Datum folgt";

    const sizeMeta = {
      600: { mann: 3, h: 4, m3: 15, label: "1-Zimmer" },
      950: { mann: 3, h: 6, m3: 30, label: "2-Zimmer" },
      1400: { mann: 4, h: 8, m3: 45, label: "3-Zimmer" },
      1900: { mann: 4, h: 10, m3: 60, label: "4-Zimmer" },
      2500: { mann: 5, h: 12, m3: 80, label: "5+ Zimmer" },
    };

    const cleaningPrices = {
      600: 350,
      950: 500,
      1400: 700,
      1900: 950,
      2500: 1200,
    };

    const guaranteePrices = {
      600: 150,
      950: 200,
      1400: 250,
      1900: 300,
      2500: 350,
    };

    let currentDistanceKm = 0;
    let geocodingFailed = false;

    function formatChf(value) {
      return "CHF " + value.toLocaleString("de-CH") + ".–";
    }

    function calculateBreakdown(km) {
      const size = parseInt(sizeSelect.value, 10);
      const stockwerke = parseInt(stockwerkInput.value || "0", 10);
      const distanceCharge = Math.max(0, km - 30) * 3;
      const stockwerkCharge = stockwerke * 50;
      const moveBase = size + stockwerkCharge + distanceCharge;

      let cleaning = 0;
      let guarantee = 0;
      if (cleaningToggle && cleaningToggle.checked) {
        cleaning = cleaningPrices[size];
        if (guaranteeToggle && guaranteeToggle.checked) {
          guarantee = guaranteePrices[size];
        }
      }

      const total = Math.ceil((moveBase + cleaning + guarantee) / 50) * 50;
      return { moveBase: moveBase, cleaning: cleaning, guarantee: guarantee, total: total };
    }

    function updateBreakdownDisplay(breakdown) {
      if (!breakdownEl) return;
      if (cleaningToggle && cleaningToggle.checked) {
        breakdownEl.classList.remove("hidden");
        if (bdMove) bdMove.textContent = breakdown.moveBase.toLocaleString("de-CH");
        if (bdCleaning) bdCleaning.textContent = breakdown.cleaning.toLocaleString("de-CH");
        if (bdCleaningRow) bdCleaningRow.classList.remove("hidden");
        if (guaranteeToggle && guaranteeToggle.checked) {
          if (bdGuarantee) bdGuarantee.textContent = breakdown.guarantee.toLocaleString("de-CH");
          if (bdGuaranteeRow) bdGuaranteeRow.classList.remove("hidden");
        } else {
          if (bdGuaranteeRow) bdGuaranteeRow.classList.add("hidden");
        }
      } else {
        breakdownEl.classList.add("hidden");
      }
    }

    function updateCleaningLabels() {
      const size = parseInt(sizeSelect.value, 10);
      if (cleaningSizeLabel) cleaningSizeLabel.textContent = sizeMeta[size].label;
      if (cleaningBasePriceEl)
        cleaningBasePriceEl.textContent = cleaningPrices[size].toLocaleString("de-CH");
      if (guaranteePriceEl)
        guaranteePriceEl.textContent = guaranteePrices[size].toLocaleString("de-CH");
    }

    function haversineKm(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const dLat = ((lat2 - lat1) * Math.PI) / 180;
      const dLon = ((lon2 - lon1) * Math.PI) / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos((lat1 * Math.PI) / 180) *
          Math.cos((lat2 * Math.PI) / 180) *
          Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    async function geocode(address) {
      const lower = address.toLowerCase();
      const query =
        lower.indexOf("schweiz") !== -1
          ? address
          : address + ", Schweiz";
      const url =
        "https://nominatim.openstreetmap.org/search?q=" +
        encodeURIComponent(query) +
        "&format=json&limit=1&countrycodes=ch";
      const response = await fetch(url, {
        headers: { "Accept-Language": "de-CH" },
      });
      if (!response.ok) throw new Error("Geocoding HTTP " + response.status);
      const data = await response.json();
      if (!data || data.length === 0) {
        throw new Error("Adresse nicht gefunden: " + address);
      }
      return {
        lat: parseFloat(data[0].lat),
        lon: parseFloat(data[0].lon),
      };
    }

    async function getCoords(address, presetLat, presetLon) {
      if (presetLat && presetLon) {
        return {
          lat: parseFloat(presetLat),
          lon: parseFloat(presetLon),
        };
      }
      return await geocode(address);
    }

    function setPrice(text, animate) {
      function apply(el) {
        if (!el) return;
        el.textContent = text;
        if (animate) {
          el.classList.remove("price-loaded");
          void el.offsetWidth;
          el.classList.add("price-loaded");
        }
      }
      apply(priceDisplay);
      apply(totalPrice);
    }

    function buildWhatsAppUrl() {
      const phone = "41000000000";
      const meta = sizeMeta[parseInt(sizeSelect.value, 10)];
      const stockwerke = parseInt(stockwerkInput.value || "0", 10);

      let msg =
        "Hallo Bari Umzüge 👋\n\n" +
        "Ich möchte eine Umzugsofferte:\n\n" +
        "📍 Auszug: " +
        from +
        "\n📍 Einzug: " +
        to +
        "\n📅 Datum: " +
        (when || "noch offen") +
        "\n🏠 Grösse: " +
        meta.label +
        "\n🪜 Stockwerke ohne Lift: " +
        stockwerke +
        "\n";

      if (geocodingFailed) {
        msg +=
          "\nBitte um konkrete Offerte basierend auf den oben genannten Angaben.\n";
      } else {
        const breakdown = calculateBreakdown(currentDistanceKm);
        msg +=
          "📏 Distanz: " +
          currentDistanceKm.toFixed(1) +
          " km\n👥 Aufwand: " +
          meta.mann +
          " Mann · " +
          meta.h +
          " Std.\n🚚 Umzugs-Pauschale: CHF " +
          breakdown.moveBase.toLocaleString("de-CH") +
          "\n";
        if (cleaningToggle && cleaningToggle.checked) {
          msg +=
            "🧹 Endreinigung: CHF " +
            breakdown.cleaning.toLocaleString("de-CH") +
            "\n";
          if (guaranteeToggle && guaranteeToggle.checked) {
            msg +=
              "✅ Abnahmegarantie: CHF " +
              breakdown.guarantee.toLocaleString("de-CH") +
              "\n";
          }
        }
        msg +=
          "\n💰 Gesamt-Richtpreis: " + formatChf(breakdown.total) + "\n";
      }

      msg += "\nVielen Dank!";
      return "https://wa.me/" + phone + "?text=" + encodeURIComponent(msg);
    }

    function updateDisplay() {
      if (geocodingFailed) {
        setPrice("Auf Anfrage", false);
        if (breakdownEl) breakdownEl.classList.add("hidden");
        return;
      }
      const meta = sizeMeta[parseInt(sizeSelect.value, 10)];
      const breakdown = calculateBreakdown(currentDistanceKm);

      setPrice(formatChf(breakdown.total), true);
      if (distanceDisplay)
        distanceDisplay.textContent = currentDistanceKm.toFixed(1) + " km";
      if (travelTime)
        travelTime.textContent = meta.mann + " Mann · " + meta.h + " Std.";
      updateBreakdownDisplay(breakdown);
    }

    async function calculateAndDisplay() {
      try {
        const a = await getCoords(from, fromLat, fromLon);
        if (!fromLat) {
          await new Promise(function (r) {
            setTimeout(r, 1100);
          });
        }
        const b = await getCoords(to, toLat, toLon);

        const straightKm = haversineKm(a.lat, a.lon, b.lat, b.lon);
        currentDistanceKm = straightKm * 1.3;
        updateDisplay();
        if (confirmBtn) confirmBtn.disabled = false;
      } catch (err) {
        console.error("Distance calculation failed:", err);
        geocodingFailed = true;
        setPrice("Auf Anfrage", true);
        if (distanceDisplay) distanceDisplay.textContent = "";
        if (travelTime)
          travelTime.textContent =
            "Distanz konnte nicht berechnet werden — Offerte nach Anfrage";
        if (disclaimer)
          disclaimer.textContent =
            "Wir berechnen den Pauschalpreis individuell. Senden Sie die Anfrage ab — wir bestätigen umgehend mit einer konkreten Offerte.";
        if (confirmBtn) confirmBtn.disabled = false;
      }
    }

    if (sizeSelect) {
      sizeSelect.addEventListener("change", function () {
        updateCleaningLabels();
        updateDisplay();
      });
    }
    if (stockwerkInput) stockwerkInput.addEventListener("input", updateDisplay);

    if (cleaningToggle) {
      cleaningToggle.addEventListener("change", function () {
        if (cleaningToggle.checked) {
          if (cleaningOptions) cleaningOptions.classList.remove("hidden");
        } else {
          if (cleaningOptions) cleaningOptions.classList.add("hidden");
          if (guaranteeToggle) guaranteeToggle.checked = false;
        }
        updateDisplay();
      });
    }
    if (guaranteeToggle) guaranteeToggle.addEventListener("change", updateDisplay);

    updateCleaningLabels();

    if (confirmBtn) {
      confirmBtn.addEventListener("click", function () {
        window.open(buildWhatsAppUrl(), "_blank");
      });
    }

    calculateAndDisplay();
  })();
</script>
