import Services from "../components/Services.astro";
import Promise from "../components/Promise.astro";
import Guarantees from "../components/Guarantees.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import Cta from "../components/Cta.astro";
import Fleet from "../components/Fleet.astro";
import Testimonials from "../components/Testimonials.astro";
import Contact from "../components/Contact.astro";

const siteUrl = "https://bari-umz-ge.vercel.app";
const title = "Bari Umzüge · Ihr Umzug in der Deutschschweiz";
const description =
