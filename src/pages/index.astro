---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BookingBar from "../components/BookingBar.astro";
import Services from "../components/Services.astro";
import Promise from "../components/Promise.astro";
import Guarantees from "../components/Guarantees.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import Cta from "../components/Cta.astro";
import Fleet from "../components/Fleet.astro";
import Testimonials from "../components/Testimonials.astro";
import Contact from "../components/Contact.astro";

const siteUrl = "https://bari-umz-ge.vercel.app";
const title = "Bari Umzüge · Ihr Umzug in der Deutschschweiz · 044 555 12 34";
const description =
  "Ihr persönlicher Umzugsservice in der Deutschschweiz. Privat- und Firmen-Umzüge, Lager, Reinigung, Entsorgung. Kostenlose Offerte: 044 555 12 34.";
const ogTitle = "Bari Umzüge · Ihr Umzug in der Deutschschweiz";
const ogDescription =
  "Privat- und Firmen-Umzüge in der ganzen Deutschschweiz. Kostenlose Offerte: 044 555 12 34.";
const twitterDescription =
  "Privat- und Firmen-Umzüge in der ganzen Deutschschweiz.";

const ldJson = {
  "@context": "https://schema.org",
  "@type": "MovingCompany",
  name: "Bari Umzüge",
  image: `${siteUrl}/og-image.jpg`,
  url: `${siteUrl}/`,
  telephone: "+41445551234",
  email: "info@bari-umzuege.ch",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Industriestrasse 23",
    addressLocality: "Zürich",
    postalCode: "8045",
    addressRegion: "ZH",
    addressCountry: "CH",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 47.3658,
    longitude: 8.5132,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ],
    opens: "07:00",
    closes: "20:00",
  },
  areaServed: [
    { "@type": "Country", name: "Switzerland" },
    { "@type": "AdministrativeArea", name: "Deutschschweiz" },
  ],
  serviceType: [
    "Privat-Umzug",
    "Firmen-Umzug",
    "Möbellager",
    "Endreinigung",
    "Entsorgung",
  ],
  currenciesAccepted: "CHF",
  paymentAccepted: "Cash, Credit Card, Invoice",
  sameAs: [],
};

// FAQ schema — Antworten leiten sich aus der Vergleichstabelle ab.
// TODO NIWAR: Antworten konsistent zu den Marketing-Aussagen halten,
// die auch in <ComparisonTable> stehen — sonst Widerspruch im Markup.
const faqLdJson = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Wie schnell bekomme ich eine Offerte?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sie erhalten Ihre kostenlose Sofort-Offerte in unter 2 Minuten direkt online. Andere Anbieter brauchen typischerweise 24–72 Stunden.",
      },
    },
    {
      "@type": "Question",
      name: "Ist der Preis verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sofort-Offerte ist ein Richtpreis. Nach einer kostenlosen Besichtigung erhalten Sie einen verbindlichen Festpreis ohne versteckte Zusatzkosten.",
      },
    },
    {
      "@type": "Question",
      name: "Was kostet ein Umzug am Wochenende?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Wochenend-Umzüge haben einen Zuschlag von 20%. Andere Anbieter verlangen typischerweise 30–50% Aufpreis.",
      },
    },
    {
      "@type": "Question",
      name: "Sind die Umzugshelfer festangestellt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja. Bari Umzüge arbeitet ausschliesslich mit festangestellten, geschulten Umzugshelfern — keine Subunternehmer.",
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  twitterDescription={twitterDescription}
  canonicalPath="/"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(ldJson)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqLdJson)}
  />

  <Hero />
  <BookingBar />
  <Services />
  <Promise />
  <Guarantees />
  <ComparisonTable />
  <Fleet />
  <Testimonials />
  <Cta />
  <Contact />
</BaseLayout>
