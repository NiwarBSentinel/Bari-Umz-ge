// FAQ schema — Antworten konsistent zu <ComparisonTable> und Disclaimer
// auf /offerte/danke. Bei Anpassungen dort: hier mitziehen.
const faqLdJson = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Wie schnell bekomme ich eine Offerte?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sie erhalten Ihre kostenlose Richt-Offerte in unter 2 Minuten direkt online. Andere Anbieter brauchen typischerweise 24–72 Stunden.",
      },
    },
    {
      "@type": "Question",
      name: "Ist der Preis verbindlich?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Die Sofort-Offerte ist eine Richt-Offerte mit Spielraum von ±15%. Aufpreise sind möglich, wenn vor Ort zusätzlicher Aufwand entsteht. Für absolute Preissicherheit bieten wir eine kostenlose Besichtigung an — danach erhalten Sie einen verbindlichen Festpreis.",
      },
    },
    {
      "@type": "Question",
      name: "Was kostet ein Umzug am Wochenende?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Wochenend-Umzüge haben übliche Zuschläge. Wir kommunizieren diese transparent in Ihrer Offerte — keine versteckten Kosten.",
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  twitterDescription={twitterDescription}
  canonicalPath="/"
>
  {/* MovingCompany Schema deaktiviert bis echte Stammdaten — siehe TODO oben */}
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqLdJson)}
  />

  <Hero />
  <BookingBar />
  <Services />
  <Promise />
  <Guarantees />
  <ComparisonTable />
  <Fleet />
  <Testimonials />
  <Cta />
  <Contact />
</BaseLayout>
